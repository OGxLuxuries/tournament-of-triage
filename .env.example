# ── Frontend (Vite) ─────────────────────────────────────────────
# Created automatically in .env.local by `npx convex dev`.
# For Vercel, set this in Project Settings → Environment Variables.
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# Linear needs no env vars: the host pastes a personal API key in-app
# (lobby LINK LINEAR card or HOST CONSOLE → LINEAR) and it is stored
# server-side on the Convex deployment.
