# ── Frontend (Vite) ─────────────────────────────────────────────
# Created automatically in .env.local by `npx convex dev`.
# For Vercel, set this in Project Settings → Environment Variables.
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# ── Convex deployment env vars ──────────────────────────────────
# These are NOT read from this file. Set them on your Convex deployment:
#   npx convex env set LINEAR_CLIENT_ID     <from Linear OAuth app>
#   npx convex env set LINEAR_CLIENT_SECRET <from Linear OAuth app>
#   npx convex env set APP_URL              https://your-app.vercel.app
#
# Linear OAuth app callback URL must be:
#   https://<your-deployment>.convex.site/linear/callback
