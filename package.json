{
  "name": "bitpoint-arcade",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "BitPoint Arcade — a retro 8-bit synthwave game-show cabinet for cooperative story pointing. React + Convex + Linear.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "dev:backend": "convex dev",
    "build": "tsc -b && vite build",
    "build:vercel": "convex deploy --cmd \"npm run build\"",
    "typecheck": "tsc -b --noEmit && tsc -p convex --noEmit",
    "preview": "vite preview"
  },
  "dependencies": {
    "convex": "^1.24.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "~5.8.3",
    "vite": "^6.3.5"
  }
}
